%REM
Agent: AAReviewerNotifier 新申請通知審核人
Generated by Domino DXL Template Kit v2.
Pattern: workflow notification
Form: DormApp (宿舍申請表)
Trigger: after document submit
Reads: studentId, studentName, applyStatus
Writes: NotifyStatus, NotifyDate
%END REM
Option Public
Option Declare

Sub Initialize
    Dim session As New NotesSession
    Dim db As NotesDatabase
    Dim doc As NotesDocument
    Dim mailDoc As NotesDocument
    Dim reviewer As NotesDocument

    Set db = session.CurrentDatabase
    Set doc = session.DocumentContext

    ' 若文件為空(直接執行測試),結束
    If doc Is Nothing Then
        Exit Sub
    End If

    ' 只在申請狀態為「已送出」或「審核中」時通知
    Dim sStatus As String
    sStatus = doc.GetItemValue("applyStatus")(0)
    If sStatus <> "已送出" And sStatus <> "審核中" Then
        Exit Sub
    End If

    ' 讀取申請資訊
    Dim sStudentId As String
    Dim sStudentName As String
    Dim sAcademicYear As String
    Dim sSemester As String
    sStudentId = doc.GetItemValue("studentId")(0)
    sStudentName = doc.GetItemValue("studentName")(0)
    sAcademicYear = doc.GetItemValue("academicYear")(0)
    sSemester = doc.GetItemValue("semester")(0)

    ' 準備通知信
    Set mailDoc = New NotesDocument(db)
    Call mailDoc.ReplaceItemValue("Form", "Memo")
    Call mailDoc.ReplaceItemValue("Subject", "【待審核】" & sAcademicYear & " " & sSemester & " 宿舍申請 - " & sStudentName & "(" & sStudentId & ")")
    Call mailDoc.ReplaceItemValue("SendTo", "DormAdmin@XRedSchool")  ' 審核群組
    Call mailDoc.ReplaceItemValue("Body", _
        "有一筆新的宿舍申請需要審核:" & Chr(10) & Chr(10) & _
        "申請人: " & sStudentName & " (" & sStudentId & ")" & Chr(10) & _
        "學年/學期: " & sAcademicYear & " " & sSemester & Chr(10) & _
        "申請日期: " & doc.GetItemValue("applyDate")(0) & Chr(10) & _
        "住宿期間: " & doc.GetItemValue("stayPeriod")(0) & Chr(10) & _
        "申請原因: " & doc.GetItemValue("applicationReasonType")(0) & Chr(10) & Chr(10) & _
        "請至 Domino Designer 中開啟 VDormApp_Pending 進行審核。" & Chr(10) & _
        "DocUNID: " & doc.UniversalID)
    Call mailDoc.Send(False)

    ' 標記已通知
    Call doc.ReplaceItemValue("NotifyStatus", "已通知審核人")
    Call doc.ReplaceItemValue("NotifyDate", Now)
    Call doc.Save(True, False)
End Sub
