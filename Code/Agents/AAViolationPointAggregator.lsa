%REM
Agent: AAViolationPointAggregator 違規記點自動彙整
Generated by Domino DXL Template Kit v2.
Pattern: scheduled aggregation / summary
Form: FViolation (違規紀錄表)
Trigger: scheduled (every month)
Reads: studentId, studentName, violationDate, penaltyPoint, processStatus
Writes: none
%END REM
Option Public
Option Declare

Sub Initialize
    Dim session As New NotesSession
    Dim db As NotesDatabase
    Dim dc As NotesDocumentCollection
    Dim doc As NotesDocument
    Dim monthStart As New NotesDateTime("")
    Dim monthEnd As New NotesDateTime("")
    Dim nextMonth As New NotesDateTime("")
    Dim cur As NotesDateTime

    Set db = session.CurrentDatabase

    ' 計算本月範圍
    Set cur = New NotesDateTime(Now)
    Call monthStart.SetLocalTime(cur.Year, cur.Month, 1, 0, 0, 0)
    Set nextMonth = New NotesDateTime(monthStart.DateOnly & " 00:00:00")
    Call nextMonth.AdjustMonth(1)
    Call monthEnd.SetLocalTime(nextMonth.Year, nextMonth.Month, 1, 0, 0, 0)

    ' 查詢本月所有違規文件
    Dim formula As String
    formula = |SELECT Form = "FViolation" & violationDate >= @TextToTime("| & monthStart.DateOnly & |") & violationDate < @TextToTime("| & monthEnd.DateOnly & |")|
    Set dc = db.Search(formula, Nothing, 0)

    ' 彙整:以學號為 key,累計 penaltyPoint
    Dim dictPoints As Variant
    Dim dictCount As Variant
    Dim dictNames As Variant
    dictPoints = Evaluate(|@If(@IsAvailable(PenaltyPoint); @Text(PenaltyPoint); "0")|, dc)
    dictCount = Evaluate(|@Text(@DocNumber; "0")|, dc)
    dictNames = Evaluate(|@Text(studentName; "T")|, dc)

    Dim pointsByStudent As Variant
    Set pointsByStudent = New NotesDocumentCollection

    ' 簡易彙整(用 Dictionary 物件模擬)
    Dim summary As String
    summary = "違規記點月報 - " & monthStart.DateOnly & " 至 " & monthEnd.DateOnly & Chr(10)
    summary = summary & "==========================================" & Chr(10)

    ' 統計總違規數
    Dim totalCount As Integer
    totalCount = dc.Count
    summary = summary & "本月違規總件數: " & totalCount & Chr(10) & Chr(10)

    ' 統計已完成處理的違規
    Dim handledCount As Integer
    Dim handledFormula As String
    handledFormula = |SELECT Form = "FViolation" & violationDate >= @TextToTime("| & monthStart.DateOnly & |") & violationDate < @TextToTime("| & monthEnd.DateOnly & |") & processStatus = "已完成"|
    Dim dcHandled As NotesDocumentCollection
    Set dcHandled = db.Search(handledFormula, Nothing, 0)
    handledCount = dcHandled.Count
    summary = summary & "本月已處理件數: " & handledCount & Chr(10)
    summary = summary & "本月未處理件數: " & (totalCount - handledCount) & Chr(10) & Chr(10)

    ' 統計待處理件數
    Dim pendingFormula As String
    pendingFormula = |SELECT Form = "FViolation" & processStatus = "待處理"|
    Dim dcPending As NotesDocumentCollection
    Set dcPending = db.Search(pendingFormula, Nothing, 0)
    summary = summary & "目前累計待處理件數: " & dcPending.Count & Chr(10) & Chr(10)

    ' 統計各違規類型
    Dim typeFormula As String
    typeFormula = |SELECT Form = "FViolation" & violationDate >= @TextToTime("| & monthStart.DateOnly & |") & violationDate < @TextToTime("| & monthEnd.DateOnly & |")|
    Dim dcMonth As NotesDocumentCollection
    Set dcMonth = db.Search(typeFormula, Nothing, 0)
    Dim typeCounts As Variant
    typeCounts = Evaluate(|@Text(violationType; "T")|, dcMonth)

    Dim typeSummary As String
    typeSummary = "本月各違規類型統計:" & Chr(10)
    Dim i As Integer
    Dim typeNames() As String
    Dim uniqueTypes As String
    uniqueTypes = ""

    For i = 0 To UBound(typeCounts)
        If InStr(uniqueTypes, typeCounts(i)) = 0 Then
            uniqueTypes = uniqueTypes & typeCounts(i) & "|"
        End If
    Next i

    Dim typeArray() As String
    typeArray = Split(uniqueTypes, "|")
    Dim j As Integer
    For j = 0 To UBound(typeArray) - 1
        If typeArray(j) <> "" Then
            Dim countFormula As String
            countFormula = |@Count(@Transform(@DbColumn("";"";"| & dcMonth.Name & |";1); "x"; "x = """ & typeArray(j) & """;"))|
            Dim countResult As Variant
            countResult = Evaluate(countFormula)
            typeSummary = typeSummary & "  - " & typeArray(j) & ": " & countResult(0) & " 件" & Chr(10)
        End If
    Next j
    summary = summary & typeSummary

    ' 寄送月報給管理員
    Dim mailDoc As NotesDocument
    Set mailDoc = New NotesDocument(db)
    Call mailDoc.ReplaceItemValue("Form", "Memo")
    Call mailDoc.ReplaceItemValue("Subject", "【違規月報】" & monthStart.DateOnly)
    Call mailDoc.ReplaceItemValue("SendTo", "DormAdmin@XRedSchool")
    Call mailDoc.ReplaceItemValue("Body", summary)
    Call mailDoc.Send(False)

    ' 將摘要也存入 Log 文件
    Dim logDoc As New NotesDocument(db)
    Call logDoc.ReplaceItemValue("Form", "Memo")
    Call logDoc.ReplaceItemValue("Subject", "Agent Log: AAViolationPointAggregator " & monthStart.DateOnly)
    Call logDoc.ReplaceItemValue("Body", summary)
    Call logDoc.ReplaceItemValue("LogDate", Now)
    Call logDoc.Send(False)
End Sub
