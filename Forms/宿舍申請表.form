<actionbar bgcolor='#2563eb' bordercolor='#1d4ed8'>
<actionbuttonstyle bgcolor='#2563eb'/><font size='9pt' color='white'/><border
 style='solid' width='0px 0px 1px' color='system'/>
<action title='送出申請' icon='7'><code event='click'><formula>
@If(@Trim(studentId) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫學號。")); "");
@If(@Trim(studentName) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫姓名。")); "");
@If(@Trim(departmentClass) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫系級 / 班級。")); "");
@If(@Trim(gender) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇性別。")); "");
@If(@Trim(academicYear) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇學年。")); "");
@If(@Trim(semester) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇學期。")); "");
@If(@Trim(stayPeriod) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇住宿期間。")); "");
@If(@Trim(applicationReasonType) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇申請原因類型。")); "");
@If(@Trim(emergencyContactName) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫緊急聯絡人姓名。")); "");
@Command([FileSave]);
@Command([FileCloseWindow])</formula></code></action>
<action title='取消' icon='127'><code event='click'><formula>
@Command([FileCloseWindow])</formula></code></action></actionbar>
