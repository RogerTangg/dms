<actionbar bgcolor='#d97706' bordercolor='#92400e'>
<actionbuttonstyle bgcolor='#d97706'/><font size='9pt' color='white'/><border
 style='solid' width='0px 0px 1px' color='system'/>
<action title='送出登記' icon='7'><code event='click'><formula>
@If(@Trim(visitorName) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫訪客姓名。")); "");
@If(@Trim(visitorGender) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇訪客性別。")); "");
@If(@Trim(studentId) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫被訪學生學號。")); "");
@If(@Trim(studentName) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫被訪學生姓名。")); "");
@If(@Trim(visitDate) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫來訪日期。")); "");
@If(@Trim(visitReason) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫來訪原因。")); "");
@Command([FileSave]);
@Command([FileCloseWindow])</formula></code></action>
<action title='取消' icon='127'><code event='click'><formula>
@Command([FileCloseWindow])</formula></code></action></actionbar>
