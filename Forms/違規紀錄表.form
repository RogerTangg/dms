<actionbar bgcolor='#dc2626' bordercolor='#991b1b'>
<actionbuttonstyle bgcolor='#dc2626'/><font size='9pt' color='white'/><border
 style='solid' width='0px 0px 1px' color='system'/>
<action title='儲存' icon='5'><code event='click'><formula>
@If(@Trim(violationDate) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫違規日期。")); "");
@If(@Trim(studentId) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請填寫學號。")); "");
@If(@Trim(violationType) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇違規類型。")); "");
@If(@Trim(violationLevel) = ""; @Return(@Prompt([Ok]; "必填欄位"; "請選擇違規等級。")); "");
@Command([FileSave]);
@Command([FileCloseWindow])</formula></code></action>
<action title='完成處理' icon='98'><code event='click'><formula>
FIELD processStatus := "已完成";
FIELD handlerName := @Name([CN]; @UserName);
FIELD handledDate := @Now;
@Command([FileSave]);
@Command([FileCloseWindow])</formula></code></action>
<action title='撤銷' icon='127'><code event='click'><formula>
FIELD processStatus := "已撤銷";
FIELD handlerName := @Name([CN]; @UserName);
FIELD handledDate := @Now;
@Command([FileSave]);
@Command([FileCloseWindow])</formula></code></action>
<action title='取消' icon='127'><code event='click'><formula>
@Command([FileCloseWindow])</formula></code></action></actionbar>
